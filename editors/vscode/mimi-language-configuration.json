{
  "comments": {
    "lineComment": "//"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"]
  ],
  "autoClosingPairs": [
    ["\"", "\""],
    ["(", ")"],
    ["[", "]"]
  ],
  "surroundingPairs": [
    ["\"", "\""],
    ["(", ")"],
    ["[", "]"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(module|type|func|fn|actor|newtype|trait|impl|if|else|for|while|match|where|async|spawn|unsafe|failure|steps|parasteps|requires|ensures|math|desc|rule|with|mms)\\b.*(:\\s*)?$",
    "decreaseIndentPattern": "^\\s*(else|\\})"
  },
  "wordPattern": "([a-zA-Z_][a-zA-Z0-9_]*)|\\?+"
}
