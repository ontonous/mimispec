{
  "name": "mimispec-vscode",
  "displayName": "MimiSpec",
  "description": "MimiSpec (.mms) language support for VS Code",
  "version": "0.5.0",
  "publisher": "ontonous",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ontonous/mimispec"
  },
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "keywords": [
    "mimispec",
    "mms",
    "mimi",
    "intent",
    "specification",
    "language"
  ],
  "activationEvents": [
    "onLanguage:mimispec"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "mimispec",
        "aliases": [
          "MimiSpec",
          "mimispec"
        ],
        "extensions": [
          ".mms"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/mms.svg",
          "dark": "./icons/mms.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "mimispec",
        "scopeName": "source.mimispec",
        "path": "./syntaxes/mimispec.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "MimiSpec",
      "properties": {
        "mimispec.binaryPath": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "Path to the mimispec CLI binary. If unset, the extension tries 'target/release/mimispec' relative to the workspace root."
        },
        "mimispec.validateOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run mimispec validation when saving .mms files."
        },
        "mimispec.validateOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "Run mimispec validation when opening .mms files."
        },
        "mimispec.collaborationMode": {
          "type": "string",
          "enum": [
            "advisory",
            "strict"
          ],
          "default": "advisory",
          "description": "Collaboration enforcement mode used by the MimiSpec 0.3 language server."
        }
      }
    },
    "commands": [
      {
        "command": "mimispec.validateFile",
        "title": "MimiSpec: Validate Current File"
      },
      {
        "command": "mimispec.refreshQueues",
        "title": "MimiSpec: Refresh Decision/Delegation Queues"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "mimispecQueues",
          "name": "MimiSpec Queues",
          "when": "editorLangId == mimispec"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "mimispec.validateFile",
          "when": "editorLangId == mimispec"
        },
        {
          "command": "mimispec.refreshQueues",
          "when": "editorLangId == mimispec"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
