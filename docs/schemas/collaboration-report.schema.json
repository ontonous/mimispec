{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ontonous/mimispec/docs/schemas/collaboration-report.schema.json",
  "title": "MimiSpec Collaboration Report",
  "description": "Provisional development summary for diagnose/workflow/materialize/profile outputs. Materialize/profile/workflow protocols are outside the MimiSpec 0.3 Core roadmap, and this schema is not a durable derivation or evidence ledger.",
  "type": "object",
  "required": ["schema_version", "kind"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.3.0-dev"
    },
    "kind": {
      "type": "string",
      "enum": ["diagnose", "workflow", "materialize", "profile"]
    },
    "path": { "type": "string" },
    "release_scope": {
      "type": "string",
      "description": "Provisional CLI label outside the MimiSpec 0.3 Core contract."
    },
    "summary": {
      "type": "object",
      "additionalProperties": true
    },
    "decision_queue": {
      "type": "array",
      "items": { "$ref": "#/$defs/queueItem" }
    },
    "delegation_queue": {
      "type": "array",
      "items": { "$ref": "#/$defs/queueItem" }
    },
    "diagnostics": {
      "type": "array",
      "items": { "$ref": "#/$defs/diagnostic" }
    },
    "plan": { "type": "object", "additionalProperties": true },
    "board": { "type": "object", "additionalProperties": true },
    "analysis": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": true,
  "$defs": {
    "queueItem": {
      "type": "object",
      "required": ["slot", "node", "state", "anchor", "footprint", "header", "span"],
      "properties": {
        "slot": {
          "type": "integer",
          "minimum": 0,
          "description": "Revision-local CommitmentSlotId; independent suffixes on one node have different IDs."
        },
        "node": {
          "type": "integer",
          "minimum": 0,
          "description": "Revision-local SourceNodeId for this report only; not a durable project identity."
        },
        "state": { "type": "string" },
        "anchor": { "type": "string" },
        "footprint": {
          "type": "string",
          "enum": [
            "entity_kind",
            "name_or_reference",
            "value",
            "clause",
            "event",
            "transition",
            "expression_operator",
            "placeholder",
            "unknown"
          ]
        },
        "header": { "type": "string" },
        "span": {
          "type": "object",
          "required": ["start", "end"],
          "properties": {
            "start": { "type": "integer", "minimum": 0 },
            "end": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "review_target": { "type": "string" }
      },
      "additionalProperties": true
    },
    "diagnostic": {
      "type": "object",
      "required": ["code", "class", "severity", "message"],
      "properties": {
        "code": { "type": "string" },
        "class": {
          "type": "string",
          "enum": [
            "syntax",
            "attachment",
            "collaboration",
            "decision",
            "delegation",
            "intent_conflict",
            "intent_gap",
            "target_gap"
          ]
        },
        "severity": {
          "type": "string",
          "enum": ["error", "warning", "info", "hint"]
        },
        "message": { "type": "string" },
        "help": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    }
  }
}
