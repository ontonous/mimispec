{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ontonous/mimispec/docs/schemas/collaboration-report.schema.json",
  "title": "MimiSpec Collaboration Report",
  "description": "Versioned envelope for diagnose and feature-gated workflow/materialize/profile reports. Experimental target payloads remain outside the MimiSpec 0.3 Core freeze.",
  "type": "object",
  "required": ["schema_version", "kind", "results"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "mimispec.collaboration/0.3"
    },
    "kind": {
      "type": "string",
      "enum": ["diagnose", "workflow", "materialize", "profile"]
    },
    "results": {
      "type": "array",
      "items": { "$ref": "#/$defs/reportResult" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "reportResult": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": { "type": "string" },
        "report": { "$ref": "#/$defs/documentDiagnostics" },
        "plan": { "type": "object", "additionalProperties": true },
        "board": { "type": "object", "additionalProperties": true },
        "analysis": { "type": "object", "additionalProperties": true }
      },
      "oneOf": [
        { "required": ["report"] },
        { "required": ["plan"] },
        { "required": ["board"] },
        { "required": ["analysis"] }
      ],
      "additionalProperties": false
    },
    "documentDiagnostics": {
      "type": "object",
      "required": ["summary", "decision_queue", "delegation_queue", "queue_tree", "diagnostics"],
      "properties": {
        "summary": { "$ref": "#/$defs/commitmentSummary" },
        "decision_queue": { "type": "array", "items": { "$ref": "#/$defs/queueItem" } },
        "delegation_queue": { "type": "array", "items": { "$ref": "#/$defs/queueItem" } },
        "queue_tree": { "$ref": "#/$defs/queueTree" },
        "diagnostics": { "type": "array", "items": { "$ref": "#/$defs/diagnostic" } }
      },
      "additionalProperties": false
    },
    "commitmentSummary": {
      "type": "object",
      "required": ["total_slots", "open", "content_review", "content_delegated", "locked", "lock_review", "lock_delegated", "strong_locked", "strong_lock_review", "strong_lock_delegated", "commit_ready"],
      "properties": {
        "total_slots": { "type": "integer", "minimum": 0 },
        "open": { "type": "integer", "minimum": 0 },
        "content_review": { "type": "integer", "minimum": 0 },
        "content_delegated": { "type": "integer", "minimum": 0 },
        "locked": { "type": "integer", "minimum": 0 },
        "lock_review": { "type": "integer", "minimum": 0 },
        "lock_delegated": { "type": "integer", "minimum": 0 },
        "strong_locked": { "type": "integer", "minimum": 0 },
        "strong_lock_review": { "type": "integer", "minimum": 0 },
        "strong_lock_delegated": { "type": "integer", "minimum": 0 },
        "commit_ready": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "queueTree": {
      "type": "object",
      "required": ["root"],
      "properties": { "root": { "$ref": "#/$defs/queueScope" } },
      "additionalProperties": false
    },
    "queueScope": {
      "type": "object",
      "required": ["scope_path", "header", "node", "span", "decision_count", "delegation_count", "children", "items"],
      "properties": {
        "scope_path": { "type": "array", "items": { "type": "string" } },
        "header": { "type": "string" },
        "node": { "type": ["integer", "null"], "minimum": 0 },
        "span": {
          "oneOf": [
            { "$ref": "#/$defs/byteSpan" },
            { "type": "null" }
          ]
        },
        "decision_count": { "type": "integer", "minimum": 0 },
        "delegation_count": { "type": "integer", "minimum": 0 },
        "children": { "type": "array", "items": { "$ref": "#/$defs/queueScope" } },
        "items": { "type": "array", "items": { "$ref": "#/$defs/queueItem" } }
      },
      "additionalProperties": false
    },
    "byteSpan": {
      "type": "object",
      "required": ["start", "end"],
      "properties": {
        "start": { "type": "integer", "minimum": 0 },
        "end": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "queueItem": {
      "type": "object",
      "required": ["slot", "node", "state", "anchor", "footprint", "header", "span"],
      "properties": {
        "slot": {
          "type": "integer",
          "minimum": 0,
          "description": "Revision-local CommitmentSlotId; independent suffixes on one node have different IDs."
        },
        "node": {
          "type": "integer",
          "minimum": 0,
          "description": "Revision-local SourceNodeId for this report only; not a durable project identity."
        },
        "state": { "type": "string" },
        "anchor": { "type": "string" },
        "footprint": {
          "type": "string",
          "enum": [
            "entity_kind",
            "name_or_reference",
            "value",
            "clause",
            "event",
            "transition",
            "expression_operator",
            "placeholder",
            "unknown"
          ]
        },
        "header": { "type": "string" },
        "span": { "$ref": "#/$defs/byteSpan" },
        "review_target": { "type": "string" }
      },
      "additionalProperties": false
    },
    "diagnostic": {
      "type": "object",
      "required": ["code", "class", "severity", "message"],
      "properties": {
        "code": { "type": "string" },
        "class": {
          "type": "string",
          "enum": [
            "syntax",
            "attachment",
            "collaboration",
            "decision",
            "delegation",
            "intent_conflict",
            "intent_gap",
            "target_gap"
          ]
        },
        "severity": {
          "type": "string",
          "enum": ["error", "warning", "info", "hint"]
        },
        "message": { "type": "string" },
        "span": {
          "oneOf": [
            { "$ref": "#/$defs/byteSpan" },
            { "type": "null" }
          ]
        },
        "help": { "type": ["string", "null"] },
        "related_nodes": { "type": "array", "items": { "type": "integer", "minimum": 0 } }
      },
      "additionalProperties": false
    }
  }
}
